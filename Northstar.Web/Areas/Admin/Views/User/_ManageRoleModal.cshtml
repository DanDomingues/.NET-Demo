@using Demo.Utility
@model ManageRoleVM
@{
    var companyStyle = Model.User.Role?.EqualsAny(SD.ROLE_USER_COMPANY, SD.ROLE_USER_EMPLOYEE) == true ?
        "display:block" :
        "display:none";
}

<div class="modal-header admin-modal-header">
    <div>
        <p class="admin-eyebrow mb-2">User Administration</p>
        <h2 class="modal-title fs-5" id="manageRoleModalLabel">Manage user role</h2>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form id="manageRoleForm" method="post" asp-action="ManageRole" asp-controller="User" asp-area="Admin">
    <input asp-for="User.Id" type="hidden" />

    <div class="modal-body admin-modal-body">
        <div class="admin-modal-field">
            <label asp-for="User.FullName"></label>
            <input asp-for="User.FullName" readonly class="form-control admin-input admin-input-readonly" />
        </div>

        <div class="admin-modal-field">
            <label asp-for="User.Role"></label>
            <select asp-for="User.Role" asp-items="@Model.Roles" id="roleField" class="form-select admin-input"></select>
            <span asp-validation-for="User.Role" class="text-danger"></span>
        </div>

        <div class="admin-modal-field" id="companyField" style="@companyStyle">
            <label asp-for="User.CompanyId"></label>
            <select asp-for="User.CompanyId" asp-items="@Model.Companies" class="form-select admin-input"></select>
            <span asp-validation-for="User.CompanyId" class="text-danger"></span>
        </div>
    </div>

    <div class="modal-footer admin-modal-footer">
        <button type="button" class="admin-btn admin-btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="admin-btn admin-btn-success">Update role</button>
    </div>
</form>
