@using Demo.Utility
@model IEnumerable<CategoryViewModel>
@{
    ViewData["Title"] = "Categories";
    ViewData["BrandName"] = "Northstar Ops";
    ViewData["BodyClass"] = "admin-ops admin-categories-page";
    ViewData["ShellClass"] = "admin-shell flex-fill";
    ViewData["NavClass"] = "admin-nav";
    ViewData["HeaderClass"] = "admin-header";
    ViewData["FooterClass"] = "admin-footer";
}

<section class="admin-section admin-categories-section">
    <div class="admin-shell-inner">
        <div class="admin-orders-header">
            <div>
                <p class="admin-eyebrow">Catalog Management</p>
                <h1>Categories</h1>
                <p class="admin-orders-subtitle">Manage storefront taxonomy, track how many products sit in each category, and adjust the display order used across the catalog.</p>
            </div>
            <button type="button" class="admin-btn admin-btn-success js-category-modal-trigger" data-id="0">
                <i class="bi bi-plus-lg"></i>
                <span>Create category</span>
            </button>
        </div>

        <div class="admin-panel admin-categories-table-panel">
            <table class="table table-hover align-middle admin-categories-table">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Products</th>
                        <th>Actions</th>
                        <th>Reorder</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vm in Model)
                    {
                        <tr>
                            <td>
                                <div class="admin-categories-name-cell">
                                    <strong>@vm.Category.Name</strong>
                                    <span class="admin-status-badge is-neutral">Category</span>
                                </div>
                            </td>
                            <td>
                                <span class="admin-categories-count">@vm.ProductCount</span>
                            </td>
                            <td>
                                <div class="admin-categories-actions" role="group" aria-label="Actions for @vm.Category.Name">
                                    <button type="button" class="admin-btn admin-btn-secondary js-category-modal-trigger" data-id="@vm.Category.Id">
                                        <i class="bi bi-pencil-square"></i>
                                        <span>Edit</span>
                                    </button>
                                    <button type="button" class="admin-btn admin-btn-danger" onclick="submitDeleteForm('categoryDeleteForm', 'categoryDeleteId', @vm.Category.Id)">
                                        <i class="bi bi-trash3"></i>
                                        <span>Delete</span>
                                    </button>
                                </div>
                            </td>
                            <td>
                                <div class="admin-categories-reorder" role="group" aria-label="Reorder @vm.Category.Name">
                                    <a asp-action="MoveDown" asp-route-id="@vm.Category.Id"
                                       class="@($"admin-reorder-btn {ViewUtility.GetNavigationEnabledClass(vm, Model, c => c.Category.DisplayOrder, 1)}")"
                                       aria-label="Move @vm.Category.Name down">
                                        <i class="bi bi-arrow-down"></i>
                                    </a>
                                    <a asp-action="MoveUp" asp-route-id="@vm.Category.Id"
                                       class="@($"admin-reorder-btn {ViewUtility.GetNavigationEnabledClass(vm, Model, c => c.Category.DisplayOrder, -1)}")"
                                       aria-label="Move @vm.Category.Name up">
                                        <i class="bi bi-arrow-up"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<form id="categoryDeleteForm" asp-area="Admin" asp-controller="Category" asp-action="Delete" method="post" class="d-none">
    <input type="hidden" id="categoryDeleteId" name="id" />
</form>

<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="categoryModalContent"></div>
    </div>
</div>

<div id="modalHost" data-modal-key="category" data-action="Upsert"></div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/shared/modal.js" asp-append-version="true"></script>
    <script src="~/js/shared/datatables-common.js" asp-append-version="true"></script>
}
