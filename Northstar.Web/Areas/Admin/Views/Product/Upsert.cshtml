@using Northstar.Utility
@model ProductVM
@{
    var isEdit = Model.Product.Id != 0;
    var actionLabel = isEdit ? "Edit" : "Create";
    var actionLabel2 = isEdit ? "Update" : "Create";


    ViewData["Title"] = $"{actionLabel} Product";
    ViewData["BrandName"] = "Northstar Ops";
    ViewData["BodyClass"] = "admin-ops admin-product-upsert-page";
    ViewData["ShellClass"] = "admin-shell flex-fill";
    ViewData["NavClass"] = "admin-nav";
    ViewData["HeaderClass"] = "admin-header";
    ViewData["FooterClass"] = "admin-footer";
}

<section class="admin-section admin-product-upsert-section">
    <div class="admin-shell-inner">
        <div class="@(isEdit ? "admin-order-detail-header" : "admin-order-detail-header admin-order-detail-header-single")">
            <div>
                <p class="admin-eyebrow">Catalog Management</p>
                <h1>@actionLabel product</h1>
                <p class="admin-orders-subtitle">Maintain product details alongside storefront media management from a single product dashboard.</p>
            </div>
            <a asp-controller="Product" asp-action="Index" class="admin-btn admin-btn-secondary text-nowrap">Back to list</a>
        </div>

        <div class="@(isEdit ? "admin-product-layout" : "admin-product-layout admin-product-layout-single")">
            <div class="admin-panel admin-product-form-panel">
                <form id="productUpsertForm" method="post" class="admin-product-form" enctype="multipart/form-data">
                    <input asp-for="Product.Id" hidden />

                    <div class="admin-section-head">
                        <h2>Details</h2>
                        <p>@actionLabel2 the product&apos;s details, pricing, and category.</p>
                    </div>

                    <div class="admin-form-grid">
                        <div class="admin-field-block">
                            <label asp-for="Product.Title"></label>
                            <input asp-for="Product.Title" class="form-control admin-input" />
                            <span asp-validation-for="Product.Title" class="text-danger"></span>
                        </div>

                        <div class="admin-field-block">
                            <label asp-for="Product.Description"></label>
                            <textarea asp-for="Product.Description" class="form-control admin-input admin-textarea"></textarea>
                        </div>

                        <div class="admin-field admin-field-half">
                            <div class="admin-field-block">
                                <label asp-for="Product.ISBN"></label>
                                <input asp-for="Product.ISBN" class="form-control admin-input" />
                                <span asp-validation-for="Product.ISBN" class="text-danger"></span>
                            </div>
                            <div class="admin-field-block">
                                <label asp-for="Product.Author"></label>
                                <input asp-for="Product.Author" class="form-control admin-input" />
                                <span asp-validation-for="Product.Author" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="admin-field admin-field-third">
                            <div class="admin-field-block">
                                <label asp-for="Product.Price"></label>
                                <input asp-for="Product.Price" class="form-control admin-input" />
                                <span asp-validation-for="Product.Price" class="text-danger"></span>
                            </div>
                            <div class="admin-field-block">
                                <label asp-for="Product.DiscountPrice"></label>
                                <input asp-for="Product.DiscountPrice" class="form-control admin-input" />
                                <span asp-validation-for="Product.DiscountPrice" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="admin-field admin-field-half admin-product-create-assets-row">
                            <div class="admin-field-block">
                                <label asp-for="Product.Category"></label>
                                <select asp-for="Product.CategoryId" asp-items="Model.CategoryList" class="form-select admin-input">
                                    <option disabled selected>--Select Category--</option>
                                </select>
                                <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
                            </div>
                            @if (!isEdit)
                            {
                                <div class="admin-field-block admin-product-create-media-field">
                                    <label asp-for="Product.Images"></label>
                                    <input type="file" name="files" multiple accept="image/*" class="form-control admin-input" />
                                    <p class="admin-input-helper mb-0">You can upload images now and manage their order after the product is created.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="admin-company-form-actions">
                        <button type="submit" class="admin-btn admin-btn-success">@actionLabel product</button>
                        <a asp-controller="Product" asp-action="Index" class="admin-btn admin-btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>

            @if (isEdit)
            {
                <aside class="admin-product-media-stack">
                    <div class="admin-panel admin-product-images-panel">
                        <div class="admin-section-head mb-1">
                            <h2>Add Media</h2>
                            <p>Upload new product images without leaving the dashboard.</p>
                        </div>

                        <div class="admin-product-media-toolbar">
                            <div class="admin-product-upload-field">
                                <label asp-for="Product.Images">Attachments</label>
                                <input type="file" name="files" form="productUpsertForm" multiple accept="image/*" class="form-control admin-input" />
                            </div>
                            <button type="submit" form="productUpsertForm" asp-action="AddImages" formnovalidate class="admin-btn admin-btn-success">Add images</button>
                        </div>
                    </div>

                    <div class="admin-panel admin-product-images-panel">
                        <div class="admin-section-head">
                            <h2>Manage Media</h2>
                            <p>Re-order and remove existing product images using the current media actions.</p>
                        </div>

                        @if (Model.Product.Images != null && Model.Product.Images.Count > 0)
                        {
                            <div class="admin-product-images-grid">
                                @foreach (var image in Model.Product.Images)
                                {
                                    <article class="admin-product-image-card">
                                        <img src="@image.Url" alt="@Model.Product.Title" class="admin-product-image-preview" />
                                        <div class="admin-product-image-actions">
                                            <a asp-action="MoveImageToTop" asp-route-prodId="@Model.Product.Id" asp-route-imageId="@image.Id"
                                               class="@($"admin-reorder-btn {ViewUtility.GetNavigationEnabledClass(image, Model.Product.Images, i => i.DisplayOrder, -1)}")"
                                               aria-label="Move image to top">
                                                <i class="bi bi-chevron-double-up"></i>
                                            </a>

                                            <a asp-action="MoveImageUp" asp-route-prodId="@Model.Product.Id" asp-route-imageId="@image.Id"
                                               class="@($"admin-reorder-btn {ViewUtility.GetNavigationEnabledClass(image, Model.Product.Images, i => i.DisplayOrder, -1)}")"
                                               aria-label="Move image up">
                                                <i class="bi bi-arrow-up"></i>
                                            </a>

                                            <a asp-action="MoveImageDown" asp-route-prodId="@Model.Product.Id" asp-route-imageId="@image.Id"
                                               class="@($"admin-reorder-btn {ViewUtility.GetNavigationEnabledClass(image, Model.Product.Images, i => i.DisplayOrder, 1)}")"
                                               aria-label="Move image down">
                                                <i class="bi bi-arrow-down"></i>
                                            </a>

                                            <a asp-action="DeleteImage" class="admin-btn admin-btn-danger" asp-route-id="@image.Id" aria-label="Delete image">
                                                <i class="bi bi-trash3"></i>
                                            </a>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="admin-product-empty-state">
                                <h3>No media yet</h3>
                                <p>Use the add media card above to upload the first product images, then manage their order here.</p>
                            </div>
                        }
                    </div>
                </aside>
            }
        </div>
    </div>
</section>

@section Scripts{
    <partial name="_ValidationScriptsPartial"/>
}
