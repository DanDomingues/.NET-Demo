@{
    var status = Context.Request.Query["status"].ToString();
    var filter = Context.Request.Query["filter"].ToString();
    var isAdminDashboard = filter == "all" && User.HasAdminRights();
    var defaultClass = string.Empty;
    var sectionClass = isAdminDashboard ? "admin-section admin-orders-section" : "northstar-section northstar-orders-section";
    var shellInnerClass = isAdminDashboard ? "admin-shell-inner" : "northstar-shell-inner";
    var ordersHeaderClass = isAdminDashboard ? "admin-orders-header" : "northstar-cart-header";
    var eyebrowClass = isAdminDashboard ? "admin-eyebrow" : "northstar-eyebrow";
    var eyebrowText = isAdminDashboard ? "Operations Dashboard" : "Northstar Supply";
    var pageHeading = isAdminDashboard ? "Order operations" : "Order history";
    var subtitleClass = isAdminDashboard ? "admin-orders-subtitle" : "northstar-cart-subtitle";
    var subtitleText = isAdminDashboard
        ? "Monitor order states, payment progress, and fulfillment from a denser internal dashboard view."
        : "Track your order history and review current order statuses in one place.";
    var filterPanelClass = isAdminDashboard ? "admin-panel admin-orders-filter-panel" : "northstar-summary-card northstar-orders-filter-panel";
    var filterHeaderClass = isAdminDashboard ? "admin-orders-filter-header" : "northstar-orders-filter-header";
    var filterDescription = isAdminDashboard ? 
        "Filter the live order table by operational state." : 
        "Use filters to quickly find the orders you need.";
    var filterChipsClass = isAdminDashboard ? "admin-filter-chips" : "northstar-filter-chips";
    var filterChipClassPrefix = isAdminDashboard ? "admin-filter-chip" : "northstar-filter-chip";
    var tablePanelClass = isAdminDashboard ? "admin-panel admin-table-panel" : "northstar-summary-card northstar-orders-table-panel";
    var classes = new Dictionary<string, (string, string)>
    {
        { "paymentpending", (defaultClass, "Payment Pending") },
        { "approved", (defaultClass, "Approved") },
        { "inprocess", (defaultClass, "In Process") },
        { "shipped", (defaultClass, "Shipped") },
        { "delivered", (defaultClass, "Delivered") },
        { "all", (defaultClass, "All") },
    };

    if (!string.IsNullOrEmpty(status) && classes.ContainsKey(status))
    {
        classes[status] = ("is-active", classes[status].Item2);
    }
    else
    {
        classes["all"] = ("is-active", classes["all"].Item2);
    }

    ViewData["Title"] = isAdminDashboard ? "Operations Orders" : "My Orders";
    ViewData["BrandName"] = isAdminDashboard ? "Northstar Ops" : "Northstar Supply";
    ViewData["BodyClass"] = isAdminDashboard ? "admin-ops admin-orders-page" : "northstar-home northstar-orders-page";
    ViewData["ShellClass"] = isAdminDashboard ? "admin-shell flex-fill" : "northstar-shell flex-fill";
    ViewData["NavClass"] = isAdminDashboard ? "admin-nav" : "northstar-nav";
    ViewData["HeaderClass"] = isAdminDashboard ? "admin-header" : "northstar-header";
    ViewData["FooterClass"] = isAdminDashboard ? "admin-footer" : "northstar-footer";
}

<section class="@sectionClass">
    <div class="@shellInnerClass">
        <div class="@ordersHeaderClass">
            <div>
                <p class="@eyebrowClass">@eyebrowText</p>
                <h1>@pageHeading</h1>
                <p class="@subtitleClass">@subtitleText</p>
            </div>
        </div>

        <div class="@filterPanelClass">
            <div class="@filterHeaderClass">
                <h2>Filter by status</h2>
                <p>@filterDescription</p>
            </div>
            <div class="@filterChipsClass">
                @foreach (var item in classes)
                {
                    <a class="@($"{filterChipClassPrefix} {classes[item.Key].Item1}")"
                       asp-controller="Order"
                       asp-action="Index"
                       asp-route-status="@item.Key"
                       asp-route-filter="@filter">
                        @classes[item.Key].Item2
                    </a>
                }
            </div>
        </div>

        <div class="@tablePanelClass">
            <table id="tblData" class="table table-hover align-middle" style="width:100%">
                <thead>
                    <tr>
                        <th>Order #</th>
                        @if(isAdminDashboard)
                        {
                            <th>Name</th>
                            <th>Phone Number</th>
                            <th>Email</th>
                        }
                        <th>Order Date</th>
                        <th>Order Status</th>
                        <th>Payment Status</th>
                        <th>Total</th>
                        <th></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/shared/datatables-common.js" asp-append-version="true"></script>
    <script src="~/js/order.js" asp-append-version="true"></script>
}
