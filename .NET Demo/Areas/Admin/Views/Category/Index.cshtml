@model IEnumerable<CategoryViewModel>

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Categories</h2>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <div class="row pb-3">
            <div class="col-12 text-end">
                <button type="button" class="btn btn-primary js-category-modal-trigger" data-category-id="0">
                    Create new category
                </button>
            </div>
        </div>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Category Name</th>
                    <th>Products</th>
                    <th>Display Order</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model)
                {
                    <tr>
                        <td>@category.Category.Name</td>
                        <td>@category.ProductCount</td>
                        <td>@category.Category.DisplayOrder</td>
                        <td>
                            <div class="m-75 btn-group" role="group">
                                <button type="button" class="btn btn-primary mx-2 js-category-modal-trigger" data-category-id="@category.Category.Id">
                                    <i class="bi bi-feather"></i> Edit
                                </button>
                                <a asp-controller="Category" asp-action="Delete" asp-route-id="@category.Category.Id" class="btn btn-danger mx-2">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="categoryModalContent"></div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (() => {
            const modalElement = document.getElementById("categoryModal");
            const modalContent = document.getElementById("categoryModalContent");
            const modal = new bootstrap.Modal(modalElement);
            const upsertUrlBase = '@Url.Action("Upsert", "Category", new { area = "Admin" })';

            const parseValidation = (scope) => {
                const forms = scope.querySelectorAll("form");
                forms.forEach((form) => {
                    $(form).removeData("validator");
                    $(form).removeData("unobtrusiveValidation");
                });

                $.validator.unobtrusive.parse(scope);
            };

            const loadModalContent = async (categoryId) => {
                const query = categoryId && categoryId !== "0" ? `?id=${categoryId}` : "";
                const response = await fetch(`${upsertUrlBase}${query}`, {
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                if (!response.ok) {
                    throw new Error("Unable to load the category form.");
                }

                modalContent.innerHTML = await response.text();
                parseValidation(modalContent);
                modal.show();
            };

            document.addEventListener("click", async (event) => {
                const trigger = event.target.closest(".js-category-modal-trigger");
                if (!trigger) {
                    return;
                }

                try {
                    await loadModalContent(trigger.dataset.categoryId);
                } catch (error) {
                    console.error(error);
                    toastr.error("Unable to open the category form.");
                }
            });

            document.addEventListener("submit", async (event) => {
                const form = event.target.closest("#categoryUpsertForm");
                if (!form) {
                    return;
                }

                event.preventDefault();
                parseValidation(form);

                if (!$(form).valid()) {
                    return;
                }

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: new FormData(form),
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        }
                    });

                    const contentType = response.headers.get("content-type") || "";

                    if (contentType.includes("application/json")) {
                        const result = await response.json();
                        if (result.success) {
                            modal.hide();
                            window.location.reload();
                        }
                        return;
                    }

                    modalContent.innerHTML = await response.text();
                    parseValidation(modalContent);
                    modal.show();
                } catch (error) {
                    console.error(error);
                    toastr.error("Unable to save the category.");
                }
            });

            modalElement.addEventListener("hidden.bs.modal", () => {
                modalContent.innerHTML = "";
            });
        })();
    </script>
}
