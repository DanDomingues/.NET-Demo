@using Demo.Utility
@model RoleManagementVM
@{
    var companyStyle = Model.User.Role?.EqualsAny(SD.ROLE_USER_COMPANY, SD.ROLE_USER_EMPLOYEE) == true ?
        "display:block" :
        "display:none";
}

<div class="modal-header">
    <h2 class="modal-title fs-5" id="roleManagementModalLabel">Manage User Role</h2>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form id="roleManagementForm" method="post" asp-action="ManageRole" asp-controller="User" asp-area="Admin">
    <input asp-for="User.Id" type="hidden" />

    <div class="modal-body">

        <div class="form-floating mb-3">
            <input asp-for="User.FullName" readonly class="form-control border-0 shadow" />
            <label asp-for="User.FullName" class="ms-2"></label>
        </div>

        <div class="form-floating mb-3">
            <select asp-for="User.Role" asp-items="@Model.Roles" class="form-select"></select>
            <label asp-for="User.Role" class="ms-2"></label>
            <span asp-validation-for="User.Role" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3" id="companyField" style="@companyStyle">
            <select asp-for="User.CompanyId" asp-items="@Model.Companies" class="form-select"></select>
            <label asp-for="User.CompanyId" class="ms-2"></label>
            <span asp-validation-for="User.CompanyId" class="text-danger"></span>
        </div>

        <div class="modal-footer">
            <button type="button" class="btn btn-outline-primary border form-control" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary form-control">Update Role</button>
        </div>

        @*genAI
        <div class="modal-footer">
            <button type="submit" class="btn btn-primary">Update Role</button>
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        </div>
        *@
    </div>
</form>

@section Scripts{
    <script>
        $(document).ready(function() {
            $('#User_Role').change(function() {
                var selection = $('#User_Role Option:Selected').text();
                if(selection == 'Company' || selection == 'Employee')
                {
                    $('#companyField').show();
                }
                else
                {
                    $('#companyField').hide();
                }
            })
        })
    </script>
}
