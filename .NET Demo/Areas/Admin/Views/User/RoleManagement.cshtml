@using Demo.Utility
@model RoleManagementVM

@{
    var companyStyle = Model.User.Role?.EqualsAny(SD.ROLE_USER_COMPANY, SD.ROLE_USER_EMPLOYEE) == true ?
        "display:block" :
        "display:none";
}

<div class="card shadow border-0 mt-4">
	<div class="card-header bg-secondary bg-gradient ml-0 py-3">
		<div class="row">
			<div class="col-12 text-center">
				<h2 class="text-white py-2">Manage User Role</h2>
			</div>
		</div>
	</div>
    <div class="card-body p-4">
		<form method="post" class="row">
			<div class="border p-3">
                <input asp-for="User.Id" hidden />
				<div class="row pb-2">
					<h2 class="text-primary">Update User Role</h2>
				</div>
				<div class="form-floating py-2 col-12">
					<input asp-for="User.FullName" readonly class="form-control border-0 shadow" />
					<label asp-for="User.FullName" class="ms-2"></label>
				</div>
                <div class="form-floating py-2 col-12">
					<select asp-for="User.Role" asp-items="@Model.Roles" class="form-select"></select>
					<label asp-for="User.Role" class="ms-2"></label>
				</div>
                <div class="form-floating py-2 col-12" id="companyField" style="@companyStyle">
                    <select asp-for="User.CompanyId" asp-items="@Model.Companies" class="form-select"></select>
                    <label asp-for="User.Company" class="ms-2"></label>
                </div>
			</div>
            <div class="row pt-2">
                <div class="col-6 col-md-3">
                    <button type="submit" class="btn btn-primary form-control">Update Role</button>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-action="Index" class="btn btn-outline-primary border form-control">
                        Back to List
                    </a>
                </div>
            </div>
		</form>
	</div>
</div>

@section Scripts{
    @{
        <partial name="_ValidationScriptsPartial" />
    }

    <script>
        $(document).ready(function() {
            $('#User_Role').change(function() {
                var selection = $('#User_Role Option:Selected').text();
                if(selection == 'Company' || selection == 'Employee')
                {
                    $('#companyField').show();
                }
                else
                {
                    $('#companyField').hide();
                }
            })
        })
    </script>
}
