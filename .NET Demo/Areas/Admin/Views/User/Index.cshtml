<div class="card shadow border-0 my-4">

    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Users</h2>
            </div>
        </div>
    </div>

        <table id="tblData" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone Number</th>
                    <th>Company</th>
                    <th>Role</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (ApplicationUser user in Model)
                {
                    <tr>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>@user.PhoneNumber</td>
                        <td>@user.Company?.Name</td>
                        <td>@user.Role</td>
                        <td>
                            <div class="m-75 btn-group" role="group">
                                <a asp-controller="User" asp-action="RoleManagement" asp-route-id=@user.Id class="btn btn-primary mx-2">
                                    <i class="bi bi-feather"></i> Edit
                                </a>
                                <a asp-controller="User" asp-action="Delete" asp-route-id=@user.Id class="btn btn-danger mx-2">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts{
    <script src="~/js/user.js"></script>
}