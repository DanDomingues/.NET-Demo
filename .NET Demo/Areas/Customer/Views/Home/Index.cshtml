@model IEnumerable<Product>

<div class="row pb-3 product-grid">
	@foreach(var product in Model)
	{
		<div class="col-lg-3 col-sm-6 d-flex product-grid-item">
			<div class="row p-1 w-100">
				<div class="col-12 p-0">
					<div class="card product-card border-0 shadow border-top border-5 rounded h-100 w-100">
						<div class="product-card-image">
							<img src="@product.ThumbnailUrl" class="card-img-top rounded" alt="@product.Title" />
						</div>
						<div class="pl-1 product-card-body d-flex flex-column flex-grow-1">
							<p class="card-title h5 text-dark opacity-75 text-uppercase text-center product-card-title">@product.Title</p>
							<p class="card-title text-warning text-center product-card-author">by <b>@product.Author</b></p>
							<p class="text-dark text-opacity-75 text-center">List price: 
								<span class="text-decoration-line-through">@product.Price.ToString("c")</span>
							</p>
							<p class="text-dark text-opacity-75 text-center">As low as: <span>@product.Price100.ToString("c")</span></p>
							<div class="mt-auto">
							<a asp-action="Details" asp-route-id="@product.Id" class="btn btn-primary bg-gradient border-0 form-control">
								Details
							</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	}
</div>
