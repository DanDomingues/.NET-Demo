{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Demo.Main",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build Demo.Main",
            "program": "${workspaceFolder}/Demo.Main/bin/Debug/net8.0/Demo.dll",
            "cwd": "${workspaceFolder}/Demo.Main",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            }
        }
    ]
}
