@model ShoppingCartItemVM
@{
    ViewData["Title"] = Model.Product.Title;
    ViewData["BrandName"] = "Northstar Supply";
    ViewData["BodyClass"] = "northstar-home northstar-product-detail-page";
    ViewData["ShellClass"] = "northstar-shell flex-fill";
    ViewData["NavClass"] = "northstar-nav";
    ViewData["HeaderClass"] = "northstar-header";
    ViewData["FooterClass"] = "northstar-footer";

    var images = Model.Product.Images.OrderBy(i => i.DisplayOrder).ToList();
}

<form method="post" class="northstar-detail-form">
    <input hidden asp-for="ProductId" />
    <input hidden asp-for="ApplicationUserId" />

    <section class="northstar-section northstar-detail-section">
        <div class="northstar-shell-inner">
            <a asp-action="Index" class="northstar-back-link">Back to collection</a>

            <div class="northstar-detail-card">
                <div class="northstar-detail-media">
                    @if (Model.Product.ImagesAreValid)
                    {
                        <div id="carouselExample" class="carousel slide northstar-detail-carousel">
                            <div class="carousel-inner">
                                @foreach (var image in images)
                                {
                                    var activeClass = image.Id == images.First().Id ? "active" : string.Empty;
                                    <div class="carousel-item @activeClass">
                                        <img src="@image.Url" class="d-block w-100 northstar-detail-image" alt="@Model.Product.Title" />
                                    </div>
                                }
                            </div>
                            <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="northstar-detail-image-fallback">
                            <img src="@Model.Product.ThumbnailUrl" class="northstar-detail-image" alt="@Model.Product.Title" />
                        </div>
                    }
                </div>

                <div class="northstar-detail-body">
                    <div class="northstar-detail-copy">
                        <p class="northstar-eyebrow">Northstar Supply</p>
                        <span class="product-category-badge">@Model.Product.Category.Name</span>
                        <h1>@Model.Product.Title</h1>
                        <p class="northstar-detail-author">by @Model.Product.Author</p>

                        <div class="northstar-detail-price-block">
                            <div class="northstar-detail-price-row">
                                <span class="northstar-detail-price">@Model.Product.DiscountPrice.FormatAsUSD()</span>
                                <span class="northstar-detail-price-caption">Discounted price</span>
                            </div>
                            <p class="northstar-detail-full-price">Full price <span>@Model.Product.Price.FormatAsUSD()</span></p>
                        </div>

                        <div class="northstar-detail-meta">
                            <div>
                                <span class="northstar-detail-meta-label">Category</span>
                                <span class="northstar-detail-meta-value">@Model.Product.Category.Name</span>
                            </div>
                            <div>
                                <span class="northstar-detail-meta-label">ISBN</span>
                                <span class="northstar-detail-meta-value">@Model.Product.ISBN</span>
                            </div>
                        </div>

                        <div class="northstar-detail-description">
                            @Html.Raw(Model.Product.Description)
                        </div>
                    </div>

                    <aside class="northstar-detail-purchase">
                        <div class="northstar-detail-purchase-card">
                            <div class="northstar-detail-summary">
                                <p class="northstar-detail-summary-label">Order summary</p>
                                <div class="northstar-detail-summary-row">
                                    <span>Discounted price</span>
                                    <strong>@Model.Product.DiscountPrice.FormatAsUSD()</strong>
                                </div>
                                <div class="northstar-detail-summary-row northstar-detail-summary-muted">
                                    <span>Full price</span>
                                    <span>@Model.Product.Price.FormatAsUSD()</span>
                                </div>
                            </div>

                            <label asp-for="Quantity" class="northstar-field-label">Quantity</label>
                            <div class="input-group northstar-quantity-group">
                                <span class="input-group-text" id="inputGroup-sizing-default">Amount</span>
                                <input asp-for="Quantity" type="number" value="1" class="form-control text-end"
                                       aria-label="Quantity"
                                       aria-describedby="inputGroup-sizing-default" />
                            </div>

                            <button type="submit" class="northstar-btn northstar-btn-primary northstar-submit-btn">Add to Cart</button>

                            <div class="northstar-detail-benefits" aria-label="Store benefits">
                                <div>
                                    <strong>Secure checkout</strong>
                                    <span>Uses the existing store checkout flow.</span>
                                </div>
                                <div>
                                    <strong>Clean ordering</strong>
                                    <span>Simple quantity selection and cart handling.</span>
                                </div>
                                <div>
                                    <strong>Everyday utility</strong>
                                    <span>Selected for steady, repeatable use.</span>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
    </section>
</form>
