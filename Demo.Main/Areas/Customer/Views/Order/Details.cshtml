@using Demo.Utility
@model OrderVM

@{
    var filter = Context.Request.Query["filter"].ToString();
    var isAdminDashboard = User.HasAdminRights();
    var header = Model.Header;
    var hasSessionMetadata = !string.IsNullOrWhiteSpace(header.SessionId) || !string.IsNullOrWhiteSpace(header.PaymentIntentId);
    var shippingDateText = header.ShippingDate == default ? "Not shipped yet" : header.ShippingDate.ToString("MMM d, yyyy");
    var orderDateText = header.OrderDate == default ? "Not available" : header.OrderDate.ToString("MMM d, yyyy");
    var paymentDateText = header.PaymentDate == default ? "Not recorded" : header.PaymentDate.ToString("MMM d, yyyy");
    var paymentDueDateText = header.PaymentDueDate == default ? "Not available" : header.PaymentDueDate.ToString("MMM d, yyyy");

    ViewData["Title"] = $"Order #{header?.Id}";
    ViewData["BrandName"] = isAdminDashboard ? "Northstar Ops" : "Northstar Supply";
    ViewData["BodyClass"] = isAdminDashboard ? "admin-ops admin-order-detail-page" : "northstar-home northstar-order-detail-page";
    ViewData["ShellClass"] = isAdminDashboard ? "admin-shell flex-fill" : "northstar-shell flex-fill";
    ViewData["NavClass"] = isAdminDashboard ? "admin-nav" : "northstar-nav";
    ViewData["HeaderClass"] = isAdminDashboard ? "admin-header" : "northstar-header";
    ViewData["FooterClass"] = isAdminDashboard ? "admin-footer" : "northstar-footer";

    string StatusClass(string? value) => value?.ToLowerInvariant() switch
    {
        "approved" => "is-success",
        "processing" => "is-info",
        "shipped" => "is-info",
        "cancelled" => "is-danger",
        "refunded" => "is-danger",
        "pending" => "is-warning",
        "approvedfordelayedpayment" => "is-warning",
        _ => "is-neutral",
    };
}

<form method="post">
    <input asp-for="Header.Id" hidden />
    <input asp-for="Header.ApplicationUserId" hidden />

    <section class="@(isAdminDashboard ? "admin-section admin-order-detail-section" : "northstar-section northstar-order-detail-section")">
        <div class="@(isAdminDashboard ? "admin-shell-inner" : "northstar-shell-inner")">
            <div class="@(isAdminDashboard ? "admin-order-detail-header" : "northstar-cart-header")">
                <div>
                    <p class="@(isAdminDashboard ? "admin-eyebrow" : "northstar-eyebrow")">@(isAdminDashboard ? "Order Operations" : "Northstar Supply")</p>
                    <h1>@(isAdminDashboard ? "Order record" : "Order details")</h1>
                    <p class="@(isAdminDashboard ? "admin-orders-subtitle" : "northstar-cart-subtitle")">
                        @(isAdminDashboard
                            ? "Update shipping, fulfillment, and operational fields as needed."
                            : "Review your shipping and contact details for this order.")
                    </p>
                </div>
                <a asp-action="Index" asp-route-filter="@filter" class="@(isAdminDashboard ? "admin-btn admin-btn-secondary" : "northstar-btn northstar-btn-secondary")">Back to orders</a>
            </div>

            <div class="@(isAdminDashboard ? "admin-order-meta-strip" : "northstar-order-meta-strip")">
                <div class="@(isAdminDashboard ? "admin-panel admin-order-meta-card" : "northstar-summary-card northstar-order-meta-card")">
                    <span class="@(isAdminDashboard ? "admin-field-label" : "northstar-detail-summary-label")">Order number</span>
                    <strong>#@header.Id</strong>
                </div>
                <div class="@(isAdminDashboard ? "admin-panel admin-order-meta-card" : "northstar-summary-card northstar-order-meta-card")">
                    <span class="@(isAdminDashboard ? "admin-field-label" : "northstar-detail-summary-label")">Order status</span>
                    <span class="@(isAdminDashboard ? $"admin-status-badge {StatusClass(header.OrderStatus)}" : $"northstar-status-badge {StatusClass(header.OrderStatus)}")">@header.OrderStatus</span>
                </div>
                <div class="@(isAdminDashboard ? "admin-panel admin-order-meta-card" : "northstar-summary-card northstar-order-meta-card")">
                    <span class="@(isAdminDashboard ? "admin-field-label" : "northstar-detail-summary-label")">Payment status</span>
                    <span class="@(isAdminDashboard ? $"admin-status-badge {StatusClass(header.PaymentStatus)}" : $"northstar-status-badge {StatusClass(header.PaymentStatus)}")">@header.PaymentStatus</span>
                </div>
                <div class="@(isAdminDashboard ? "admin-panel admin-order-meta-card" : "northstar-summary-card northstar-order-meta-card")">
                    <span class="@(isAdminDashboard ? "admin-field-label" : "northstar-detail-summary-label")">Order total</span>
                    <strong>@header.OrderTotal.FormatAsUSD()</strong>
                </div>
            </div>

            <div class="@(isAdminDashboard ? "admin-order-detail-layout" : "northstar-summary-layout")">
                <div class="@(isAdminDashboard ? "admin-order-main" : "northstar-order-main")">
                    <section class="@(isAdminDashboard ? "admin-order-form-panel admin-panel" : "northstar-summary-details northstar-summary-card")">
                        <div class="@(isAdminDashboard ? "admin-section-head" : "northstar-summary-section-head")">
                            <h2>Customer</h2>
                            <p>@(isAdminDashboard ? "Primary contact information for this order." : "Contact details associated with this order.")</p>
                        </div>

                        <div class="order-section-grid">
                            @if (isAdminDashboard)
                            {
                                <div class="admin-field admin-field-half">
                                    <div class="admin-field-block">
                                        <label asp-for="Header.FirstName"></label>
                                        <input asp-for="Header.FirstName" class="form-control admin-input" />
                                    </div>
                                    <div class="admin-field-block">
                                        <label asp-for="Header.LastName"></label>
                                        <input asp-for="Header.LastName" class="form-control admin-input" />
                                    </div>
                                </div>

                                <div class="admin-field admin-field-half">
                                    <div class="admin-field-block">
                                        <label asp-for="Header.PhoneNumber"></label>
                                        <input asp-for="Header.PhoneNumber" class="form-control admin-input" />
                                    </div>
                                    <div class="admin-field-block">
                                        <label asp-for="Header.ApplicationUser.Email"></label>
                                        <input asp-for="Header.ApplicationUser.Email" class="form-control admin-input" />
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="order-display-grid">
                                    <div class="order-display-field">
                                        <span class="order-display-label">First Name</span>
                                        <strong>@header.FirstName</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">Last Name</span>
                                        <strong>@header.LastName</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">Phone</span>
                                        <strong>@header.PhoneNumber</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">Email</span>
                                        <strong>@header.ApplicationUser.Email</strong>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>

                    <section class="@(isAdminDashboard ? "admin-order-form-panel admin-panel" : "northstar-summary-details northstar-summary-card")">
                        <div class="@(isAdminDashboard ? "admin-section-head" : "northstar-summary-section-head")">
                            <h2>Shipping / Fulfillment</h2>
                            <p>@(isAdminDashboard ? "Shipping address and fulfillment inputs." : "Delivery address and fulfillment information.")</p>
                        </div>

                        <div class="order-section-grid">
                            @if (isAdminDashboard)
                            {
                                <div class="admin-field-block">
                                    <label asp-for="Header.StreetAddress"></label>
                                    <input asp-for="Header.StreetAddress" class="form-control admin-input" />
                                </div>

                                <div class="admin-field admin-field-third">
                                    <div class="admin-field-block">
                                        <label asp-for="Header.City"></label>
                                        <input asp-for="Header.City" class="form-control admin-input" />
                                    </div>
                                    <div class="admin-field-block">
                                        <label asp-for="Header.State"></label>
                                        <input asp-for="Header.State" class="form-control admin-input" />
                                    </div>
                                    <div class="admin-field-block">
                                        <label asp-for="Header.PostalCode"></label>
                                        <input asp-for="Header.PostalCode" class="form-control admin-input" />
                                    </div>
                                </div>

                                <div class="admin-field admin-field-half">
                                    <div class="admin-field-block">
                                        <label asp-for="Header.Carrier"></label>
                                        <select asp-for="Header.Carrier" asp-items="@(new SelectList(Model.Carriers))" class="form-select admin-input">
                                            <option value="">Select carrier</option>
                                        </select>
                                    </div>
                                    <div class="admin-field-block">
                                        <label asp-for="Header.TrackingNumber"></label>
                                        <input asp-for="Header.TrackingNumber" class="form-control admin-input" />
                                    </div>
                                </div>

                                <div class="admin-field admin-field-half">
                                    <div class="admin-field-block">
                                        <label asp-for="Header.ShippingDate"></label>
                                        <div class="order-display-field order-display-field-muted">
                                            <span class="order-display-label">Shipping date</span>
                                            <strong>@shippingDateText</strong>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="order-display-grid">
                                    <div class="order-display-field order-display-field-wide">
                                        <span class="order-display-label">Street Address</span>
                                        <strong>@header.StreetAddress</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">City</span>
                                        <strong>@header.City</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">State</span>
                                        <strong>@header.State</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">Postal Code</span>
                                        <strong>@header.PostalCode</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">Carrier</span>
                                        <strong>@(string.IsNullOrWhiteSpace(header.Carrier) ? "Not assigned" : header.Carrier)</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">Tracking Number</span>
                                            <strong>@(string.IsNullOrWhiteSpace(header.TrackingNumber) ? "Pending" : header.TrackingNumber)</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">Shipping Date</span>
                                        <strong>@shippingDateText</strong>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>

                    <section class="@(isAdminDashboard ? "admin-order-form-panel admin-panel" : "northstar-summary-details northstar-summary-card")">
                        <div class="@(isAdminDashboard ? "admin-section-head" : "northstar-summary-section-head")">
                            <h2>Order Timeline</h2>
                            <p>@(isAdminDashboard ? "System-generated milestones and status markers." : "Key dates and status updates for this order.")</p>
                        </div>

                        <div class="order-display-grid">
                            <div class="order-display-field order-display-field-muted">
                                <span class="order-display-label">Order Date</span>
                                <strong>@orderDateText</strong>
                            </div>
                            <div class="order-display-field order-display-field-muted">
                                <span class="order-display-label">@(header.SessionId != null ? "Payment Date" : "Payment Due Date")</span>
                                <strong>@(header.SessionId != null ? paymentDateText : paymentDueDateText)</strong>
                            </div>
                            <div class="order-display-field order-display-field-muted">
                                <span class="order-display-label">Order Status</span>
                                <strong>@header.OrderStatus</strong>
                            </div>
                            <div class="order-display-field order-display-field-muted">
                                <span class="order-display-label">Payment Status</span>
                                <strong>@header.PaymentStatus</strong>
                            </div>
                        </div>
                    </section>

                    @if (isAdminDashboard && hasSessionMetadata)
                    {
                        <section class="admin-panel admin-order-technical-panel">
                            <details class="order-technical-details">
                                <summary>
                                    <span>
                                        <strong>Technical details</strong>
                                        <small>Session and payment identifiers</small>
                                    </span>
                                </summary>

                                <div class="order-display-grid order-display-grid-compact">
                                    <div class="order-display-field order-display-field-muted">
                                        <span class="order-display-label">Session ID</span>
                                        <strong>@(string.IsNullOrWhiteSpace(header.SessionId) ? "Not available" : header.SessionId)</strong>
                                    </div>
                                    <div class="order-display-field order-display-field-muted">
                                        <span class="order-display-label">Payment Intent ID</span>
                                        <strong>@(string.IsNullOrWhiteSpace(header.PaymentIntentId) ? "Not available" : header.PaymentIntentId)</strong>
                                    </div>
                                </div>
                            </details>
                        </section>
                    }
                </div>

                <aside class="@(isAdminDashboard ? "admin-order-sidebar" : "northstar-summary-sidebar")">
                    <div class="@(isAdminDashboard ? "admin-panel admin-order-summary-card" : "northstar-summary-card")">
                        <div class="@(isAdminDashboard ? "admin-section-head" : "northstar-summary-section-head")">
                            <h2>Order items</h2>
                            <p>@Model.Details.Count() line items.</p>
                        </div>

                        <div class="@(isAdminDashboard ? "admin-order-items" : "northstar-summary-items")">
                            @foreach (var item in Model.Details)
                            {
                                <article class="@(isAdminDashboard ? "admin-order-item" : "northstar-summary-item")">
                                    <div>
                                        <h3>@item.Product.Title</h3>
                                        <p>Quantity: @item.Count</p>
                                    </div>
                                    <div class="@(isAdminDashboard ? "admin-order-item-pricing" : "northstar-summary-item-pricing")">
                                        <strong>@item.TotalCost.FormatAsUSD()</strong>
                                        <span>@item.Product.Price.FormatAsUSD() per unit</span>
                                    </div>
                                </article>
                            }
                        </div>

                        <div class="@(isAdminDashboard ? "admin-order-total" : "northstar-summary-total")">
                            <span>Total</span>
                            <strong>@header.OrderTotal.FormatAsUSD()</strong>
                        </div>
                    </div>

                    <div class="@(isAdminDashboard ? "admin-panel admin-order-actions-panel" : "northstar-summary-card")">
                        <div class="@(isAdminDashboard ? "admin-section-head" : "northstar-summary-section-head")">
                            <h2>Actions</h2>
                            <p>@(isAdminDashboard ? "Order management and status actions." : "Actions currently available for this order.")</p>
                        </div>

                        <div class="@(isAdminDashboard ? "admin-action-stack" : "northstar-action-stack")">
                            @if (header.PaymentStatus.Equals(SD.PAYMENT_STATUS_DELAYED) && header.OrderStatus.Equals(SD.ORDER_STATUS_SHIPPED))
                            {
                                <button asp-action="RequestPayment" class="@(isAdminDashboard ? "admin-btn admin-btn-success" : "northstar-btn northstar-btn-primary northstar-submit-btn")">Pay now</button>
                            }

                            @if (isAdminDashboard)
                            {
                                <button asp-action="UpdateDetails" class="admin-btn admin-btn-warning">Save changes</button>
                                @if (header.OrderStatus.Equals(SD.ORDER_STATUS_APPROVED))
                                {
                                    <button asp-action="StartProcess" class="admin-btn admin-btn-success">Start processing</button>
                                }
                                @if (header.OrderStatus.Equals(SD.ORDER_STATUS_PROCESSING))
                                {
                                    <button asp-action="ShipOrder" onclick="return validateInput()" class="admin-btn admin-btn-success">Ship order</button>
                                }
                            }

                            @if (!header.OrderStatus.EqualsAny(SD.PAYMENT_STATUS_REFUNDED, SD.ORDER_STATUS_SHIPPED, SD.ORDER_STATUS_CANCELLED))
                            {
                                <button asp-action="CancelOrder" class="@(isAdminDashboard ? "admin-btn admin-btn-danger" : "northstar-btn northstar-btn-secondary northstar-order-cancel-btn")">Cancel order</button>
                            }
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </section>
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script>
        function validateInput()
        {
            if(document.getElementById("Header_TrackingNumber").value == "")
            {
                Swal.fire({
                    icon: 'error',
                    title: 'error',
                    text: 'Tracking number invalid'
                });
                return false;
            }
            if(document.getElementById("Header_Carrier").value == "")
            {
                Swal.fire({
                    icon: 'error',
                    title: 'error',
                    text: 'Carrier invalid'
                });
                return false;
            }
            return true;
        }
    </script>
}
