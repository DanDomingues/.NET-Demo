@using Demo.Utility
@model OrderVM

@{
    var header = Model.Header ?? throw new Exception("No header found");
    var filter = Context.Request.Query["filter"].ToString();
    var hasSessionMetadata = !string.IsNullOrWhiteSpace(header.SessionId) || !string.IsNullOrWhiteSpace(header.PaymentIntentId);
    var isAdminDashboard = User.HasAdminRights() && filter == "all";

    //LABELS
    var brandName = isAdminDashboard ? "Northstar Ops" : "Northstar Supply";
    var brandEyebrow = isAdminDashboard ? "Order Operations" : "Northstar Supply";
    var pageTitle = isAdminDashboard ? "Order record" : "Order details";
    var pageSubtitle = isAdminDashboard
        ? "Update shipping, fulfillment, and operational fields as needed."
        : "Review your shipping information, items, and order status.";
    var customerSectionCopy = isAdminDashboard ? "Primary contact information for this order." : "Contact details associated with this order.";
    var shippingSectionCopy = isAdminDashboard ? "Shipping address and fulfillment inputs." : "Delivery address and tracking information for this order.";
    var timelineSectionCopy = isAdminDashboard ? "System-generated milestones and status markers." : "Important dates and status updates for this order.";
    var actionsSectionCopy = isAdminDashboard ? "Order management and status actions." : "Actions currently available for this order.";
    var lineItemsLabel = isAdminDashboard ? $"{Model.Details.Count()} line items" : "Items included in this order";
    var paymentTimelineLabel = header.SessionId != null ? "Payment Date" : "Payment Due Date";

    //CLASSES
    var bodyClass = isAdminDashboard ? "admin-ops admin-order-detail-page" : "northstar-home northstar-order-detail-page";
    var shellClass = isAdminDashboard ? "admin-shell flex-fill" : "northstar-shell flex-fill";
    var navClass = isAdminDashboard ? "admin-nav" : "northstar-nav";
    var headerClass = isAdminDashboard ? "admin-header" : "northstar-header";
    var footerClass = isAdminDashboard ? "admin-footer" : "northstar-footer";
    var sectionClass = isAdminDashboard ? "admin-section admin-order-detail-section" : "northstar-section northstar-order-detail-section";
    var shellInnerClass = isAdminDashboard ? "admin-shell-inner" : "northstar-shell-inner";
    var pageHeaderClass = isAdminDashboard ? "admin-order-detail-header" : "northstar-cart-header";
    var eyebrowClass = isAdminDashboard ? "admin-eyebrow" : "northstar-eyebrow";
    var subtitleClass = isAdminDashboard ? "admin-orders-subtitle" : "northstar-cart-subtitle";
    var backButtonClass = isAdminDashboard ? "admin-btn admin-btn-secondary" : "northstar-btn northstar-btn-secondary";
    var metaStripClass = isAdminDashboard ? "admin-order-meta-strip" : "northstar-order-meta-strip";
    var metaCardClass = isAdminDashboard ? "admin-panel admin-order-meta-card" : "northstar-summary-card northstar-order-meta-card";
    var metaLabelClass = isAdminDashboard ? "admin-field-label" : "northstar-detail-summary-label";
    var layoutClass = isAdminDashboard ? "admin-order-detail-layout" : "northstar-summary-layout";
    var mainColumnClass = isAdminDashboard ? "admin-order-main" : "northstar-order-main";
    var detailSectionClass = isAdminDashboard ? "admin-order-form-panel admin-panel" : "northstar-summary-details northstar-summary-card";
    var sectionHeadClass = isAdminDashboard ? "admin-section-head" : "northstar-summary-section-head";
    var sidebarClass = isAdminDashboard ? "admin-order-sidebar" : "northstar-summary-sidebar";
    var itemsCardClass = isAdminDashboard ? "admin-panel admin-order-summary-card" : "northstar-summary-card";
    var itemsListClass = isAdminDashboard ? "admin-order-items" : "northstar-summary-items";
    var itemClass = isAdminDashboard ? "admin-order-item" : "northstar-summary-item";
    var itemPricingClass = isAdminDashboard ? "admin-order-item-pricing" : "northstar-summary-item-pricing";
    var totalClass = isAdminDashboard ? "admin-order-total" : "northstar-summary-total";
    var actionsCardClass = isAdminDashboard ? "admin-panel admin-order-actions-panel" : "northstar-summary-card";
    var actionStackClass = isAdminDashboard ? "admin-action-stack" : "northstar-action-stack";
    var payButtonClass = isAdminDashboard ? "admin-btn admin-btn-success" : "northstar-btn northstar-btn-primary northstar-submit-btn";
    var cancelButtonClass = isAdminDashboard ? "admin-btn admin-btn-danger" : "northstar-btn northstar-btn-secondary northstar-order-cancel-btn";
    var orderStatusBadgeClass = isAdminDashboard ? $"admin-status-badge {StatusClass(header.OrderStatus)}" : $"northstar-status-badge {StatusClass(header.OrderStatus)}";
    var paymentStatusBadgeClass = isAdminDashboard ? $"admin-status-badge {StatusClass(header.PaymentStatus)}" : $"northstar-status-badge {StatusClass(header.PaymentStatus)}";
    
    //LOGIC
    var canShowCarrier = header.OrderStatus.EqualsAny(SD.ORDER_STATUS_PROCESSING, SD.ORDER_STATUS_SHIPPED);
    var canEditCarrier = isAdminDashboard && header.OrderStatus.Equals(SD.ORDER_STATUS_PROCESSING);
    var canPerformPayment = header.PaymentStatus.Equals(SD.PAYMENT_STATUS_DELAYED) && header.OrderStatus.Equals(SD.ORDER_STATUS_SHIPPED);
    var canRequestCancel = !header.OrderStatus.EqualsAny(SD.PAYMENT_STATUS_REFUNDED, SD.ORDER_STATUS_SHIPPED, SD.ORDER_STATUS_PROCESSING, SD.ORDER_STATUS_CANCELLED);

    string FormatDateTime(DateTime value, string fallback) => value == default ? fallback : value.ToString("dd/MM/yyyy HH:mm:ss");
    string FormatDateOnly(DateOnly value, string fallback) => value == default ? fallback : value.ToString("dd/MM/yyyy");

    //MODEL DRIVEN
    var shippingDateText = FormatDateTime(header.ShippingDate, "Not shipped yet");
    var orderDateText = FormatDateTime(header.OrderDate, "Not available");
    var paymentDateText = FormatDateTime(header.PaymentDate, "Not recorded");
    var paymentDueDateText = FormatDateOnly(header.PaymentDueDate, "Not available");
    var paymentTimelineValue = header.SessionId != null ? paymentDateText : paymentDueDateText;
    var carrierText = string.IsNullOrWhiteSpace(header.Carrier) ? "Not assigned" : header.Carrier;
    var trackingNumberText = string.IsNullOrWhiteSpace(header.TrackingNumber) ? "Pending" : header.TrackingNumber;
    var sessionIdText = string.IsNullOrWhiteSpace(header.SessionId) ? "Not available" : header.SessionId;
    var paymentIntentText = string.IsNullOrWhiteSpace(header.PaymentIntentId) ? "Not available" : header.PaymentIntentId;

    //VIEW DATA
    ViewData["Title"] = $"Order #{header?.Id}";
    ViewData["BrandName"] = brandName;
    ViewData["BodyClass"] = bodyClass;
    ViewData["ShellClass"] = shellClass;
    ViewData["NavClass"] = navClass;
    ViewData["HeaderClass"] = headerClass;
    ViewData["FooterClass"] = footerClass;

    string StatusClass(string? value) => value?.ToLowerInvariant() switch
    {
        "approved" => "is-success",
        "processing" => "is-info",
        "shipped" => "is-info",
        "cancelled" => "is-danger",
        "refunded" => "is-danger",
        "pending" => "is-warning",
        "approvedfordelayedpayment" => "is-warning",
        _ => "is-neutral",
    };
}

<form method="post">
    <input asp-for="Header.Id" hidden />
    <input asp-for="Header.ApplicationUserId" hidden />

    <section class="@sectionClass">
        <div class="@shellInnerClass">
            <div class="@pageHeaderClass">
                <div>
                    <p class="@eyebrowClass">@brandEyebrow</p>
                    <h1>@pageTitle</h1>
                    <p class="@subtitleClass">@pageSubtitle</p>
                </div>
                <a asp-action="Index" asp-route-filter="@filter" class="@backButtonClass">Back to orders</a>
            </div>

            <div class="@metaStripClass">
                <div class="@metaCardClass">
                    <span class="@metaLabelClass">Order number</span>
                    <strong>#@header.Id</strong>
                </div>
                <div class="@metaCardClass">
                    <span class="@metaLabelClass">Order status</span>
                    <div class="order-summary-status">
                        <span class="@orderStatusBadgeClass">@header.OrderStatus</span>
                    </div>
                </div>
                <div class="@metaCardClass">
                    <span class="@metaLabelClass">Payment status</span>
                    <div class="order-summary-status">
                        <span class="@paymentStatusBadgeClass">@header.PaymentStatus</span>
                    </div>
                </div>
                <div class="@metaCardClass">
                    <span class="@metaLabelClass">Order total</span>
                    <strong>@header.OrderTotal.FormatAsUSD()</strong>
                </div>
            </div>

            <div class="@layoutClass">
                <div class="@mainColumnClass">
                    <section class="@detailSectionClass">
                        <div class="@sectionHeadClass">
                            <h2>Customer</h2>
                            <p>@customerSectionCopy</p>
                        </div>

                        <div class="order-section-grid">
                            @if (isAdminDashboard)
                            {
                                <div class="admin-field admin-field-half">
                                    <div class="admin-field-block">
                                        <label asp-for="Header.FirstName"></label>
                                        <input asp-for="Header.FirstName" class="form-control admin-input" />
                                    </div>
                                    <div class="admin-field-block">
                                        <label asp-for="Header.LastName"></label>
                                        <input asp-for="Header.LastName" class="form-control admin-input" />
                                    </div>
                                </div>

                                <div class="admin-field admin-field-half">
                                    <div class="admin-field-block">
                                        <label asp-for="Header.PhoneNumber"></label>
                                        <input asp-for="Header.PhoneNumber" class="form-control admin-input" />
                                    </div>
                                    <div class="admin-field-block">
                                        <label for="Header_ApplicationUser_Email">Email</label>
                                        <input id="Header_ApplicationUser_Email" value="@header.ApplicationUser.Email" class="form-control admin-input admin-input-readonly" readonly />
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="order-display-grid">
                                    <div class="order-display-field">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.FirstName)</span>
                                        <strong>@header.FirstName</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.LastName)</span>
                                        <strong>@header.LastName</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.PhoneNumber)</span>
                                        <strong>@header.PhoneNumber</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">Email</span>
                                        <strong>@header.ApplicationUser.Email</strong>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>

                    <section class="@detailSectionClass">
                        <div class="@sectionHeadClass">
                            <h2>Shipping / Fulfillment</h2>
                            <p>@shippingSectionCopy</p>
                        </div>

                        <div class="order-section-grid">
                            @if (isAdminDashboard)
                            {
                                <div class="admin-field-block">
                                    <label asp-for="Header.StreetAddress"></label>
                                    <input asp-for="Header.StreetAddress" class="form-control admin-input" />
                                </div>

                                <div class="admin-field admin-field-third">
                                    <div class="admin-field-block">
                                        <label asp-for="Header.City"></label>
                                        <input asp-for="Header.City" class="form-control admin-input" />
                                    </div>
                                    <div class="admin-field-block">
                                        <label asp-for="Header.State"></label>
                                        <input asp-for="Header.State" class="form-control admin-input" />
                                    </div>
                                    <div class="admin-field-block">
                                        <label asp-for="Header.PostalCode"></label>
                                        <input asp-for="Header.PostalCode" class="form-control admin-input" />
                                    </div>
                                </div>

                                <div class="admin-field admin-field-half">
                                    @if (canShowCarrier)
                                    {
                                        <div class="admin-field-block">
                                            <label asp-for="Header.Carrier"></label>
                                            @if (canEditCarrier)
                                            {
                                                <select asp-for="Header.Carrier" asp-items="@(new SelectList(Model.Carriers))" class="form-select admin-input">
                                                    <option value="">Select carrier</option>
                                                </select>
                                            }
                                            else
                                            {
                                                <input asp-for="Header.Carrier" class="form-control admin-input admin-input-readonly" readonly />
                                            }
                                        </div>
                                    }
                                    <div class="admin-field-block">
                                        <label asp-for="Header.TrackingNumber"></label>
                                        <input asp-for="Header.TrackingNumber" class="form-control admin-input admin-input-readonly" readonly />
                                    </div>
                                </div>

                                <div class="admin-field admin-field-half">
                                    <div class="admin-field-block">
                                        <label asp-for="Header.ShippingDate"></label>
                                        <input asp-for="Header.ShippingDate" class="form-control admin-input admin-input-readonly" readonly />
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="order-display-grid">
                                    <div class="order-display-field order-display-field-wide">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.StreetAddress)</span>
                                        <strong>@header.StreetAddress</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.City)</span>
                                        <strong>@header.City</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.State)</span>
                                        <strong>@header.State</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.PostalCode)</span>
                                        <strong>@header.PostalCode</strong>
                                    </div>
                                    @if (canShowCarrier)
                                    {
                                        <div class="order-display-field">
                                            <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.Carrier)</span>
                                            <strong>@carrierText</strong>
                                        </div>
                                    }
                                    <div class="order-display-field">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.TrackingNumber)</span>
                                        <strong>@trackingNumberText</strong>
                                    </div>
                                    <div class="order-display-field">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.ShippingDate)</span>
                                        <strong>@shippingDateText</strong>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>

                    <section class="@detailSectionClass">
                        <div class="@sectionHeadClass">
                            <h2>Order Timeline</h2>
                            <p>@timelineSectionCopy</p>
                        </div>

                        <div class="order-display-grid">
                            <div class="order-display-field order-display-field-muted">
                                <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.OrderDate)</span>
                                <strong>@orderDateText</strong>
                            </div>
                            <div class="order-display-field order-display-field-muted">
                                <span class="order-display-label">@paymentTimelineLabel</span>
                                <strong>@paymentTimelineValue</strong>
                            </div>
                            <div class="order-display-field order-display-field-muted">
                                <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.OrderStatus)</span>
                                <strong>@header.OrderStatus</strong>
                            </div>
                            <div class="order-display-field order-display-field-muted">
                                <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.PaymentStatus)</span>
                                <strong>@header.PaymentStatus</strong>
                            </div>
                        </div>
                    </section>

                    @if (isAdminDashboard && hasSessionMetadata)
                    {
                        <section class="admin-panel admin-order-technical-panel">
                            <details class="order-technical-details">
                                <summary>
                                    <span>
                                        <strong>Technical details</strong>
                                        <small>Session and payment identifiers</small>
                                    </span>
                                </summary>

                                <div class="order-display-grid order-display-grid-compact">
                                    <div class="order-display-field order-display-field-muted">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.SessionId)</span>
                                        <strong>@sessionIdText</strong>
                                    </div>
                                    <div class="order-display-field order-display-field-muted">
                                        <span class="order-display-label">@Html.DisplayNameFor(m => m.Header.PaymentIntentId)</span>
                                        <strong>@paymentIntentText</strong>
                                    </div>
                                </div>
                            </details>
                        </section>
                    }
                </div>

                <aside class="@sidebarClass">
                    <div class="@itemsCardClass">
                        <div class="@sectionHeadClass">
                            <h2>Order items</h2>
                            <p>@lineItemsLabel</p>
                        </div>

                        <div class="@itemsListClass">
                            @foreach (var item in Model.Details)
                            {
                                <article class="@itemClass">
                                    <div>
                                        <h3>@item.Product.Title</h3>
                                        <p>Quantity: @item.Count</p>
                                    </div>
                                    <div class="@itemPricingClass">
                                        <strong>@item.TotalCost.FormatAsUSD()</strong>
                                        <span>@item.Product.Price.FormatAsUSD() per unit</span>
                                    </div>
                                </article>
                            }
                        </div>

                        <div class="@totalClass">
                            <span>Total</span>
                            <strong>@header.OrderTotal.FormatAsUSD()</strong>
                        </div>

                        @if (!isAdminDashboard)
                        {
                            <div class="northstar-order-summary-actions @actionStackClass">
                                @if (canPerformPayment)
                                {
                                    <button asp-action="RequestPayment" class="@payButtonClass">Pay now</button>
                                }
                                @if (canRequestCancel)
                                {
                                    <button asp-action="CancelOrder" class="@cancelButtonClass">Cancel order</button>
                                }
                            </div>
                        }
                    </div>

                    @if (isAdminDashboard)
                    {
                        <div class="@actionsCardClass">
                            <div class="@sectionHeadClass">
                                <h2>Actions</h2>
                                <p>@actionsSectionCopy</p>
                            </div>

                            <div class="@actionStackClass">
                                <button asp-action="UpdateDetails" class="admin-btn admin-btn-warning">Save changes</button>
                                @if (header.OrderStatus.Equals(SD.ORDER_STATUS_APPROVED))
                                {
                                    <button asp-action="StartProcess" class="admin-btn admin-btn-success">Start processing</button>
                                }
                                @if (header.OrderStatus.Equals(SD.ORDER_STATUS_PROCESSING))
                                {
                                    <button asp-action="ShipOrder" onclick="return validateInput()" class="admin-btn admin-btn-success">Ship order</button>
                                }
                                @if (canRequestCancel)
                                {
                                    <button asp-action="CancelOrder" class="@cancelButtonClass">Cancel order</button>
                                }
                            </div>
                        </div>
                    }
                </aside>
            </div>
        </div>
    </section>
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script>
        function validateInput()
        {
            if(document.getElementById("Header_TrackingNumber").value == "")
            {
                Swal.fire({
                    icon: 'error',
                    title: 'error',
                    text: 'Tracking number invalid'
                });
                return false;
            }
            if(document.getElementById("Header_Carrier").value == "")
            {
                Swal.fire({
                    icon: 'error',
                    title: 'error',
                    text: 'Carrier invalid'
                });
                return false;
            }
            return true;
        }
    </script>
}
