@model ShoppingCartVM
@{
    ViewData["Title"] = "Order Summary";
    ViewData["BrandName"] = "Northstar Supply";
    ViewData["BodyClass"] = "northstar-home northstar-summary-page";
    ViewData["ShellClass"] = "northstar-shell flex-fill";
    ViewData["NavClass"] = "northstar-nav";
    ViewData["HeaderClass"] = "northstar-header";
    ViewData["FooterClass"] = "northstar-footer";

    var arrivalStart = DateTime.Now.AddDays(7).ToShortDateString();
    var arrivalEnd = DateTime.Now.AddDays(14).ToShortDateString();
}

<form method="post" class="northstar-summary-form">
    <input hidden asp-for="ProductList" />
    <input hidden asp-for="OrderHeader.ApplicationUserId" />
    <input hidden asp-for="OrderHeader.OrderTotal" />
    <input hidden asp-for="OrderHeader.Id" />

    <section class="northstar-section northstar-summary-section">
        <div class="northstar-shell-inner">
            <div class="northstar-cart-header">
                <div>
                    <p class="northstar-eyebrow">Northstar Supply</p>
                    <h1>Order summary</h1>
                    <p class="northstar-cart-subtitle">Confirm delivery details and review your order before continuing to payment.</p>
                </div>
                <a asp-action="Index" class="northstar-btn northstar-btn-secondary">Back to cart</a>
            </div>

            <div class="northstar-summary-layout">
                <section class="northstar-summary-details">
                    <div class="northstar-summary-details-card">
                        <div class="northstar-summary-section-head">
                            <h2>Delivery details</h2>
                            <p>We'll use this information for checkout, confirmation, and delivery routing.</p>
                        </div>

                        <div class="northstar-summary-fields">
                            <div class="northstar-summary-field-grid">
                                <div class="northstar-summary-field">
                                    <label asp-for="OrderHeader.FirstName"></label>
                                    <input asp-for="OrderHeader.FirstName" class="form-control northstar-input" />
                                    <span asp-validation-for="OrderHeader.FirstName" class="text-danger"></span>
                                </div>
                                <div class="northstar-summary-field">
                                    <label asp-for="OrderHeader.LastName"></label>
                                    <input asp-for="OrderHeader.LastName" class="form-control northstar-input" />
                                    <span asp-validation-for="OrderHeader.LastName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="northstar-summary-field">
                                <label asp-for="OrderHeader.PhoneNumber"></label>
                                <input asp-for="OrderHeader.PhoneNumber" class="form-control northstar-input" />
                                <span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger"></span>
                            </div>

                            <div class="northstar-summary-field">
                                <label asp-for="OrderHeader.StreetAddress"></label>
                                <input asp-for="OrderHeader.StreetAddress" class="form-control northstar-input" />
                                <span asp-validation-for="OrderHeader.StreetAddress" class="text-danger"></span>
                            </div>

                            <div class="northstar-summary-field-grid northstar-summary-field-grid-tight">
                                <div class="northstar-summary-field">
                                    <label asp-for="OrderHeader.City"></label>
                                    <input asp-for="OrderHeader.City" class="form-control northstar-input" />
                                    <span asp-validation-for="OrderHeader.City" class="text-danger"></span>
                                </div>
                                <div class="northstar-summary-field">
                                    <label asp-for="OrderHeader.State"></label>
                                    <input asp-for="OrderHeader.State" class="form-control northstar-input" />
                                    <span asp-validation-for="OrderHeader.State" class="text-danger"></span>
                                </div>
                                <div class="northstar-summary-field">
                                    <label asp-for="OrderHeader.PostalCode"></label>
                                    <input asp-for="OrderHeader.PostalCode" class="form-control northstar-input" />
                                    <span asp-validation-for="OrderHeader.PostalCode" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <aside class="northstar-summary-sidebar">
                    <div class="northstar-summary-card">
                        <div class="northstar-summary-section-head">
                            <h2>Order review</h2>
                            <p>@Model.ProductList.Count() items ready for checkout.</p>
                        </div>

                        <div class="northstar-summary-items">
                            @foreach (var item in Model.ProductList)
                            {
                                <article class="northstar-summary-item">
                                    <div>
                                        <h3>@item.Product.Title</h3>
                                        <p>Qty @item.Count</p>
                                    </div>
                                    <div class="northstar-summary-item-pricing">
                                        <strong>@item.TotalCost.FormatAsUSD()</strong>
                                        <span>@item.Product.Price100.FormatAsUSD() each</span>
                                    </div>
                                </article>
                            }
                        </div>

                        <div class="northstar-summary-total">
                            <span>Total</span>
                            <strong>@Model.OrderHeader.OrderTotal.FormatAsUSD()</strong>
                        </div>

                        <div class="northstar-summary-arrival">
                            <span class="northstar-detail-summary-label">Estimated arrival</span>
                            <p>@arrivalStart - @arrivalEnd</p>
                        </div>

                        <button type="submit" value="Place Order" class="northstar-btn northstar-btn-primary northstar-submit-btn">Continue to payment</button>
                    </div>
                </aside>
            </div>
        </div>
    </section>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
