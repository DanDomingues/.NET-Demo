@model int
@{
    ViewData["Title"] = "Order Confirmed";
    ViewData["BrandName"] = "Northstar Supply";
    ViewData["BodyClass"] = "northstar-home northstar-confirmation-page";
    ViewData["ShellClass"] = "northstar-shell flex-fill";
    ViewData["NavClass"] = "northstar-nav";
    ViewData["HeaderClass"] = "northstar-header";
    ViewData["FooterClass"] = "northstar-footer";
}

<section class="northstar-section northstar-confirmation-section">
    <div class="northstar-shell-inner">
        <div class="northstar-confirmation-card">
            <div class="northstar-confirmation-badge">
                <i class="bi bi-check2-circle" aria-hidden="true"></i>
                <span>Confirmed</span>
            </div>

            <p class="northstar-eyebrow">Northstar Supply</p>
            <h1>Order placed successfully</h1>
            <p class="northstar-confirmation-lead">Your checkout is complete and your order is now in the system.</p>

            <div class="northstar-confirmation-order">
                <span class="northstar-detail-summary-label">Order number</span>
                <strong>#@Model</strong>
            </div>

            <div class="northstar-confirmation-copy">
                <p>You can review the details and track progress anytime from My Orders.</p>
            </div>

            <div class="northstar-confirmation-actions">
                <a asp-area="Customer" asp-controller="Order" asp-action="Index" asp-route-filter="user" class="northstar-btn northstar-btn-primary">View my orders</a>
                <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="northstar-btn northstar-btn-secondary">Return to storefront</a>
            </div>
        </div>
    </div>
</section>
