@page
@model RegisterModel
@using Demo.Utility
@{
    var isAdminPortal = User.IsInRole(SD.ROLE_USER_ADMIN);
    var sectionClass = isAdminPortal ? "admin-section admin-auth-section" : "northstar-section northstar-auth-section";
    var shellInnerClass = isAdminPortal ? "admin-shell-inner" : "northstar-shell-inner";
    var authCardClass = isAdminPortal ? "admin-auth-card" : "northstar-auth-card";
    var authIntroClass = isAdminPortal ? "admin-auth-intro" : "northstar-auth-intro";
    var eyebrowClass = isAdminPortal ? "admin-eyebrow" : "northstar-eyebrow";
    var eyebrowText = isAdminPortal ? "User Administration" : "Northstar Supply";
    var headingText = isAdminPortal ? "Create user account" : "Create your account";
    var subtitleClass = isAdminPortal ? "admin-orders-subtitle" : "northstar-auth-copy";
    var subtitleText = isAdminPortal
        ? "Provision a new account with role and company assignment using the existing registration flow."
        : "Set up your Northstar account to shop, order, and manage your details.";
    var formClass = isAdminPortal ? "admin-auth-form" : "northstar-auth-form northstar-auth-form-wide";
    var fieldGridClass = isAdminPortal ? "admin-field admin-field-half" : "northstar-summary-field-grid";
    var fieldBlockClass = isAdminPortal ? "admin-field-block" : "northstar-summary-field";
    var labelClass = isAdminPortal ? "" : "northstar-auth-label";
    var inputClass = isAdminPortal ? "admin-input" : "northstar-input";
    var submitButtonClass = isAdminPortal ? "admin-btn admin-btn-success" : "northstar-btn northstar-btn-primary northstar-submit-btn";

    ViewData["Title"] = "Register";
    ViewData["BrandName"] = isAdminPortal ? "Northstar Ops" : "Northstar Supply";
    ViewData["BodyClass"] = isAdminPortal ? "admin-ops admin-auth-page" : "northstar-home northstar-auth-page";
    ViewData["ShellClass"] = isAdminPortal ? "admin-shell flex-fill" : "northstar-shell flex-fill";
    ViewData["NavClass"] = isAdminPortal ? "admin-nav" : "northstar-nav";
    ViewData["HeaderClass"] = isAdminPortal ? "admin-header" : "northstar-header";
    ViewData["FooterClass"] = isAdminPortal ? "admin-footer" : "northstar-footer";
}

<section class="@sectionClass">
    <div class="@shellInnerClass">
        <div class="@authCardClass">
            <div class="@authIntroClass">
                <p class="@eyebrowClass">@eyebrowText</p>
                <h1>@headingText</h1>
                <p class="@subtitleClass">
                    @subtitleText
                </p>
            </div>

            <form id="registerForm" class="@formClass" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="@fieldBlockClass">
                    <label asp-for="Input.Email" class="@labelClass">Email</label>
                    <input asp-for="Input.Email" class="form-control @inputClass" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="@fieldGridClass">
                    <div class="@fieldBlockClass">
                        <label asp-for="Input.Password" class="@labelClass">Password</label>
                        <input asp-for="Input.Password" class="form-control @inputClass" autocomplete="new-password" aria-required="true" placeholder="Password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="@fieldBlockClass">
                        <label asp-for="Input.ConfirmPassword" class="@labelClass">Confirm Password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control @inputClass" autocomplete="new-password" aria-required="true" placeholder="Confirm Password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <div class="@fieldGridClass">
                    <div class="@fieldBlockClass">
                        <label asp-for="Input.FirstName" class="@labelClass">First Name</label>
                        <input asp-for="Input.FirstName" class="form-control @inputClass" aria-required="true" />
                    </div>
                    <div class="@fieldBlockClass">
                        <label asp-for="Input.LastName" class="@labelClass">Last Name</label>
                        <input asp-for="Input.LastName" class="form-control @inputClass" aria-required="true" />
                    </div>
                </div>

                <div class="@fieldGridClass">
                    <div class="@fieldBlockClass">
                        <label asp-for="Input.City" class="@labelClass">City</label>
                        <input asp-for="Input.City" class="form-control @inputClass" aria-required="true" />
                    </div>
                    <div class="@fieldBlockClass">
                        <label asp-for="Input.State" class="@labelClass">State</label>
                        <input asp-for="Input.State" class="form-control @inputClass" aria-required="true" />
                    </div>
                </div>

                <div class="@fieldGridClass">
                    <div class="@fieldBlockClass">
                        <label asp-for="Input.PostalCode" class="@labelClass">Postal Code</label>
                        <input asp-for="Input.PostalCode" class="form-control @inputClass" aria-required="true" />
                    </div>
                    <div class="@fieldBlockClass">
                        <label asp-for="Input.PhoneNumber" class="@labelClass">Phone Number</label>
                        <input asp-for="Input.PhoneNumber" class="form-control @inputClass" aria-required="true" />
                    </div>
                </div>

                @if(!Defines.ROLE_SELECTION_LOCK_ACTIVE || User.IsInRole(SD.ROLE_USER_ADMIN))
                {
                    <div class="@fieldGridClass">
                        <div class="@fieldBlockClass">
                            <label asp-for="Input.Role" class="@labelClass">Role</label>
                            <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select @inputClass">
                                <option disabled selected>-Select Role-</option>
                            </select>
                        </div>
                        <div class="@fieldBlockClass" id="CompanyIdInput" style="display:none">
                            <label asp-for="Input.CompanyId" class="@labelClass">Company</label>
                            <select asp-for="Input.CompanyId" asp-items="@Model.Input.CompanyList" class="form-select @inputClass">
                                <option disabled selected>-Select Company-</option>
                            </select>
                        </div>
                    </div>
                }

                <button id="registerSubmit" type="submit" class="@submitButtonClass">Register</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function()
        {
            $('#Input_Role').change(function()
            {
                const selection = $('#Input_Role Option:Selected').text();
                const shouldShowCompany = selection === 'Company' || selection === 'Employee';
                $('#CompanyIdInput').toggle(shouldShowCompany);
            })
        })
    </script>
}
