@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
    ViewData["BrandName"] = "Northstar Supply";
    ViewData["BodyClass"] = "northstar-home northstar-auth-page";
    ViewData["ShellClass"] = "northstar-shell flex-fill";
    ViewData["NavClass"] = "northstar-nav";
    ViewData["HeaderClass"] = "northstar-header";
    ViewData["FooterClass"] = "northstar-footer";
}

<section class="northstar-section northstar-auth-section">
    <div class="northstar-shell-inner">
        <div class="northstar-auth-card">
            <div class="northstar-auth-intro">
                <p class="northstar-eyebrow">Northstar Supply</p>
                <h1>Welcome back</h1>
                <p class="northstar-auth-copy">Sign in to continue shopping, review orders, and manage your account.</p>
            </div>

            <section class="northstar-auth-form-panel">
                <form id="account" method="post" class="northstar-auth-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="northstar-summary-field">
                        <label asp-for="Input.Email" class="northstar-auth-label">Email</label>
                        <input asp-for="Input.Email" class="form-control northstar-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="northstar-summary-field">
                        <label asp-for="Input.Password" class="northstar-auth-label">Password</label>
                        <input asp-for="Input.Password" class="form-control northstar-input" autocomplete="current-password" aria-required="true" placeholder="Password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <label asp-for="Input.RememberMe" class="northstar-auth-checkbox">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                    </label>

                    <button id="login-submit" type="submit" class="northstar-btn northstar-btn-primary northstar-submit-btn">Log in</button>

                    <p class="northstar-auth-helper">
                        Need an account?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create one</a>
                    </p>
                </form>
            </section>
        </div>
    </div>
</section>

@section Scripts
{
    <partial name="_ValidationScriptsPartial"/>
}
