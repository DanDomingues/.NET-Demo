@model Company
@{
    var isEdit = Model.Id != 0;
    var actionLabel = isEdit ? "Save changes" : "Create company";
    var title = isEdit ? "Edit company" : "Create company";
}

<div class="modal-header admin-modal-header">
    <div>
        <p class="admin-eyebrow mb-2">Companies</p>
        <h2 class="modal-title fs-5" id="companyModalLabel">@title</h2>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form id="companyForm" method="post" asp-action="Upsert" asp-controller="Company" asp-area="Admin">
    <input asp-for="Id" type="hidden" />

    <div class="modal-body admin-modal-body">
        <div asp-validation-summary="ModelOnly" class="text-danger admin-modal-validation"></div>

        <div class="admin-modal-field">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control admin-input" autocomplete="organization" placeholder="Northstar Holdings" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="admin-modal-field">
            <label asp-for="PhoneNumber"></label>
            <input asp-for="PhoneNumber" class="form-control admin-input" autocomplete="tel" inputmode="tel" placeholder="(555) 123-4567" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>
    </div>

    <div class="modal-footer admin-modal-footer">
        <button type="button" class="admin-btn admin-btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="admin-btn admin-btn-success">@actionLabel</button>
    </div>
</form>
