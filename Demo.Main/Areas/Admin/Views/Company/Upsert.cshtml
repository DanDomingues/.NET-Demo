@model Company
@{
    var isEdit = Model.Id != 0;
    var actionLabel = isEdit ? "Update" : "Create";

    ViewData["Title"] = $"{actionLabel} Company";
    ViewData["BrandName"] = "Northstar Ops";
    ViewData["BodyClass"] = "admin-ops admin-company-upsert-page";
    ViewData["ShellClass"] = "admin-shell flex-fill";
    ViewData["NavClass"] = "admin-nav";
    ViewData["HeaderClass"] = "admin-header";
    ViewData["FooterClass"] = "admin-footer";
}

<section class="admin-section admin-company-upsert-section">
    <div class="admin-shell-inner">
        <div class="admin-order-detail-header">
            <div>
                <p class="admin-eyebrow">Account Management</p>
                <h1>@actionLabel company</h1>
                <p class="admin-orders-subtitle">Create or update company records used for internal account administration and order workflows.</p>
            </div>
            <a asp-controller="Company" asp-action="Index" class="admin-btn admin-btn-secondary">Back to list</a>
        </div>

        <div class="admin-panel admin-company-form-panel">
            <form method="post" class="admin-company-form" enctype="multipart/form-data">
                <input asp-for="Id" hidden />

                <div class="admin-section-head">
                    <h2>Company profile</h2>
                    <p>Update the core record, contact number, and address information. Existing model binding and save behavior remain unchanged.</p>
                </div>

                <div class="admin-form-grid">
                    <div class="admin-field-block">
                        <label asp-for="Name"></label>
                        <input asp-for="Name" class="form-control admin-input" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="admin-field-block">
                        <label asp-for="PhoneNumber"></label>
                        <input asp-for="PhoneNumber" class="form-control admin-input" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="admin-field-block">
                        <label asp-for="StreetAddress"></label>
                        <input asp-for="StreetAddress" class="form-control admin-input" />
                        <span asp-validation-for="StreetAddress" class="text-danger"></span>
                    </div>

                    <div class="admin-field admin-field-third">
                        <div class="admin-field-block">
                            <label asp-for="City"></label>
                            <input asp-for="City" class="form-control admin-input" />
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>
                        <div class="admin-field-block">
                            <label asp-for="State"></label>
                            <input asp-for="State" class="form-control admin-input" />
                            <span asp-validation-for="State" class="text-danger"></span>
                        </div>
                        <div class="admin-field-block">
                            <label asp-for="PostalCode"></label>
                            <input asp-for="PostalCode" class="form-control admin-input" />
                            <span asp-validation-for="PostalCode" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="admin-company-form-actions">
                    <button type="submit" class="admin-btn admin-btn-success">@actionLabel company</button>
                    <a asp-controller="Company" asp-action="Index" class="admin-btn admin-btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts{
    <partial name="_ValidationScriptsPartial"/>
}
