@{
    ViewData["Title"] = "Companies";
    ViewData["BrandName"] = "Northstar Ops";
    ViewData["BodyClass"] = "admin-ops admin-companies-page";
    ViewData["ShellClass"] = "admin-shell flex-fill";
    ViewData["NavClass"] = "admin-nav";
    ViewData["HeaderClass"] = "admin-header";
    ViewData["FooterClass"] = "admin-footer";
}

<section class="admin-section admin-companies-section">
    <div class="admin-shell-inner">
        <div class="admin-orders-header">
            <div>
                <p class="admin-eyebrow">Account Management</p>
                <h1>Companies</h1>
                <p class="admin-orders-subtitle">Maintain company accounts, billing addresses, and contact records used across staff and customer management workflows.</p>
            </div>
            <a asp-controller="Company" asp-action="Upsert" class="admin-btn admin-btn-success">
                <i class="bi bi-plus-lg"></i>
                <span>Create company</span>
            </a>
        </div>

        <div class="admin-panel admin-companies-table-panel">
            <table id="tblData" class="table table-hover align-middle admin-companies-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Address</th>
                        <th>City</th>
                        <th>State</th>
                        <th>Postal Code</th>
                        <th>Phone Number</th>
                        <th></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</section>

@section Scripts
{
    <script src="~/js/company.js" asp-append-version="true"></script>
    <script src="~/js/shared/datatables-common.js" asp-append-version="true"></script>
}
