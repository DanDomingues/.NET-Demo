@model Category
@{
    var isNew = Model.Id == 0;
}

<div class="modal-header admin-modal-header">
    <div>
        <p class="admin-eyebrow mb-2">Catalog Management</p>
        <h2 class="modal-title fs-5" id="categoryModalLabel">@(isNew ? "Create category" : "Edit category")</h2>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form id="categoryForm" method="post" asp-action="Upsert" asp-controller="Category" asp-area="Admin">
    <input asp-for="Id" type="hidden" />

    <div class="modal-body admin-modal-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="admin-modal-field">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control admin-input" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="admin-modal-field">
            <label asp-for="DisplayOrder"></label>
            <input asp-for="DisplayOrder" class="form-control admin-input" />
            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
        </div>
    </div>

    <div class="modal-footer admin-modal-footer">
        <button type="button" class="admin-btn admin-btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="admin-btn admin-btn-success">@(isNew ? "Create category" : "Save changes")</button>
    </div>
</form>
