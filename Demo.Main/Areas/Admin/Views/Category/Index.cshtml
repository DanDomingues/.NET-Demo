@model IEnumerable<CategoryViewModel>
@{
    var enabled = "";
    var disabled = "disabled";
    string GetUpArrowStyle(Category element)
    {
        return element.Id == Model.First().Category.Id ? disabled : enabled;
    }
    string GetDownArrowStyle(Category element)
    {
        return element.Id == Model.Last().Category.Id ? disabled : enabled;
    }
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Categories</h2>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <div class="row pb-3">
            <div class="col-12 text-end">
                <button type="button" class="btn btn-primary js-category-modal-trigger" data-id="0">
                    Create new
                </button>
            </div>
        </div>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Category Name</th>
                    <th>Products</th>
                    <th>Display Order</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var vm in Model)
                {
                    <tr>
                        <td>@vm.Category.Name</td>
                        <td>@vm.ProductCount</td>
                        <td>@vm.Category.DisplayOrder</td>
                        <td>
                            <div class="m-75 btn-group" role="group">
                                <button type="button" class="btn btn-primary mx-2 js-category-modal-trigger" data-id="@vm.Category.Id">
                                    <i class="bi bi-feather"></i> Edit
                                </button>
                                <a asp-controller="Category" asp-action="Delete" asp-route-id="@vm.Category.Id" class="btn btn-danger mx-2">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </a>
                            </div>
                        </td>
                        <td>
                            <a asp-action="MoveDown" asp-route-id="@vm.Category.Id"
                            class=@($"btn btn-secondary mx-2 js-category-move-down {GetDownArrowStyle(vm.Category)}")>
                                <i class="bi bi-arrow-down"></i>
                            </a>
                            <a asp-action="MoveUp" asp-route-id="@vm.Category.Id" 
                            class=@($"btn btn-secondary mx-2 js-category-move-up {GetUpArrowStyle(vm.Category)}")>
                                <i class="bi bi-arrow-up"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="categoryModalContent"></div>
    </div>
</div>

<div id="modalHost" data-modal-key="category" data-action="Upsert"></div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/modal.js" asp-append-version="true"></script>
}
