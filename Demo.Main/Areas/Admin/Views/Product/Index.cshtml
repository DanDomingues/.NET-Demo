@{
    ViewData["Title"] = "Products";
    ViewData["BrandName"] = "Northstar Ops";
    ViewData["BodyClass"] = "admin-ops admin-products-page";
    ViewData["ShellClass"] = "admin-shell flex-fill";
    ViewData["NavClass"] = "admin-nav";
    ViewData["HeaderClass"] = "admin-header";
    ViewData["FooterClass"] = "admin-footer";
}

<section class="admin-section admin-products-section">
    <div class="admin-shell-inner">
        <div class="admin-orders-header">
            <div>
                <p class="admin-eyebrow">Catalog Management</p>
                <h1>Products</h1>
                <p class="admin-orders-subtitle">Manage product records, pricing tiers, category assignments, and media assets used throughout the storefront.</p>
            </div>
            <a asp-controller="Product" asp-action="Upsert" class="admin-btn admin-btn-success">
                <i class="bi bi-plus-lg"></i>
                <span>Create product</span>
            </a>
        </div>

        <div class="admin-panel admin-products-table-panel">
            <table id="tblData" class="table table-hover align-middle admin-products-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>ISBN</th>
                        <th>Price</th>
                        <th>Discounted Price</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th></th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</section>

@section Scripts{
    <script src="~/js/shared/datatables-common.js" asp-append-version="true"></script>
    <script src="~/js/product.js" asp-append-version="true"></script>
}
